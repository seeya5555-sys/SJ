[Unit]
Description=Turny Functional Site (gunicorn)
After=network.target

[Service]
User=opc
WorkingDirectory=/opt/turny-site
Environment=TRMT_DEBUG=0
Environment=PORT=5000
EnvironmentFile=-/etc/trmt.env
ExecStartPre=/bin/bash -lc "cd /opt/turny-site && .venv/bin/python3 -c \"import app; app.init_db(drop=False); app._auto_migrate()\""
ExecStart=/opt/turny-site/.venv/bin/gunicorn -w 1 --threads 8 -k gthread -b 0.0.0.0:5000 --timeout 60 --graceful-timeout 30 --max-requests 500 --max-requests-jitter 50 --error-logfile - app:app
Restart=always
RestartSec=5
MemoryHigh=300M
MemoryMax=400M

[Install]
WantedBy=multi-user.target
