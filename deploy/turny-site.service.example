[Unit]
Description=Turny Functional Site
After=network.target

[Service]
User=opc
WorkingDirectory=/home/opc/turny-functional-site
Environment=TRMT_DEBUG=0
Environment=PORT=5000
ExecStart=/home/opc/turny-functional-site/.venv/bin/python /home/opc/turny-functional-site/app.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
